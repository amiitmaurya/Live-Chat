@{
    ViewData["Title"] = "Home Page";
}


<style>
    body {
        background: #f1f3f6;
    }

    .chat-container {
        max-width: 800px;
        margin: 40px auto;
        background: #fff;
        border-radius: 12px;
        box-shadow: 0 4px 20px rgba(0,0,0,0.1);
        overflow: hidden;
    }

    .chat-header {
        background: #0d6efd;
        color: white;
        padding: 15px;
        font-size: 20px;
        font-weight: bold;
        text-align: center;
    }

    .chat-body {
        height: 350px;
        overflow-y: auto;
        padding: 15px;
        background: #f8f9fa;
    }

    #messageList li {
        list-style: none;
        margin-bottom: 10px;
        padding: 10px;
        background: #e9ecef;
        border-radius: 8px;
    }

    .chat-footer {
        display: flex;
        gap: 10px;
        padding: 10px;
        border-top: 1px solid #ddd;
    }

    .chat-footer input {
        flex: 1;
    }

    .username-box {
        padding: 30px;
        text-align: center;
    }
</style>

<div class="chat-container">

    <div class="chat-header">
        💬 SignalR Chat App
    </div>

    <!-- USERNAME AREA -->
    <div id="userinfo" class="username-box">
        <h4>Enter Username</h4>
        <input type="text" id="username" class="form-control mb-2" placeholder="Your name..." />
        <button class="btn btn-primary w-100" onclick="SetUsername()">Join Chat</button>
    </div>

    <!-- CHAT AREA -->
    <div id="messagearea" style="display:none;">
        <div class="p-2 text-center">
            Joined as: <b id="username1"></b>
        </div>

        <div class="chat-body">
            <ul id="messageList" class="p-0"></ul>
        </div>

        <div class="chat-footer">
            <input type="text" id="message" class="form-control" placeholder="Type a message..." />
            <button class="btn btn-success" id="sendButton">Send</button>
        </div>
    </div>

</div>
<script src="~/lib/microsoft/signalr/dist/browser/signalr.js"></script>
<script src="~/lib/microsoft/signalr/dist/browser/signalr.min.js"></script>


<script>
    "use strict";

    var connection = new signalR.HubConnectionBuilder().withUrl("/chatHub").build();
    var username = "";

    document.getElementById("sendButton").disabled = true;

    connection.on("ReceiveMessage", function (user, message) {
        var li = document.createElement("li");
        li.innerHTML = "<b>" + user + ":</b> " + message;
        document.getElementById("messageList").appendChild(li);
    });

    connection.start().then(function () {
        document.getElementById("sendButton").disabled = false;
    }).catch(function (err) {
        return console.error(err.toString());
    });

    document.getElementById("sendButton").addEventListener("click", function (event) {
        var message = document.getElementById("message").value;

        if (message === "") return;

        connection.invoke("SendMessage", username, message)
            .then(function () {
                document.getElementById("message").value = "";
            })
            .catch(function (err) {
                return console.error(err.toString());
            });

        event.preventDefault();
    });

    function SetUsername() {
        var usernameinput = document.getElementById("username").value;

        if (usernameinput === "") {
            alert("Please enter a user name");
            return;
        }

        username = usernameinput;

        document.getElementById("userinfo").style.display = "none";
        document.getElementById("messagearea").style.display = "block";
        document.getElementById("username1").innerText = usernameinput;
    }
</script>